### Example 2: Data Processing Pipeline

A common scenario: processing CSV files and writing results. The wrong exit can corrupt your output.

```python
import sys
import os
import logging
from contextlib import contextmanager

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

@contextmanager
def data_pipeline(input_file, output_file):
    """Context manager for data processing"""
    logger.info(f"Opening {input_file}")
    in_f = open(input_file, 'r')
    out_f = open(output_file, 'w')
    
    try:
        yield in_f, out_f
    finally:
        logger.info("Closing files")
        in_f.close()
        out_f.close()

# WRONG ❌
def process_data_wrong():
    with data_pipeline('input.csv', 'output.csv') as (in_f, out_f):
        for line in in_f:
            processed = process_line(line)
            out_f.write(processed)
            
            if error_condition:
                os._exit(1)  # Files not closed! Output incomplete!

# RIGHT ✓
def process_data_right():
    try:
        with data_pipeline('input.csv', 'output.csv') as (in_f, out_f):
            for line in in_f:
                processed = process_line(line)
                out_f.write(processed)
                
                if error_condition:
                    raise ValueError("Processing error")
    except ValueError as e:
        logger.error(f"Error: {e}")
        sys.exit(1)  # Files properly closed via context manager ✓

if __name__ == '__main__':
    process_data_right()
```

