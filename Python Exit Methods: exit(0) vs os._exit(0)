### Example 3: Proper Multiprocessing

This shows the **correct** use of both exit methods in the same program.

```python
import os
import sys
import multiprocessing
import logging

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

def child_worker(worker_id, tasks):
    """Worker process - uses os._exit()"""
    logger.info(f"Worker {worker_id} started")
    
    try:
        for task in tasks:
            result = process_task(task)
            logger.info(f"Worker {worker_id} completed task {task}")
    except Exception as e:
        logger.error(f"Worker {worker_id} error: {e}")
        os._exit(1)  # Correct - child process immediate exit
    
    logger.info(f"Worker {worker_id} finished")
    os._exit(0)  # Correct - avoid parent's cleanup in child

def parent_main():
    """Parent process - uses sys.exit()"""
    logger.info("Parent starting workers")
    
    # Register parent's cleanup
    import atexit
    atexit.register(lambda: logger.info("Parent cleanup"))
    
    tasks = list(range(100))
    chunk_size = 25
    task_chunks = [tasks[i:i+chunk_size] for i in range(0, len(tasks), chunk_size)]
    
    # Create workers
    workers = []
    for i, chunk in enumerate(task_chunks):
        p = multiprocessing.Process(target=child_worker, args=(i, chunk))
        workers.append(p)
        p.start()
    
    # Wait for all workers
    for p in workers:
        p.join()
    
    logger.info("All workers completed")
    sys.exit(0)  # Correct - parent uses clean exit

if __name__ == '__main__':
    parent_main()
```

**Why this works:**
- Children use `os._exit(0)` to avoid running parent's `atexit` handlers
- Parent uses `sys.exit(0)` to run its own cleanup properly
- Each process cleans up its own resources appropriately

